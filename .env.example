# PostgreSQL Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/webscraper

# Example for local development
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/webscraper

# Scraping Service API Keys

# Hyperbrowser - Best for long runs and messy sites
# Get key at: https://hyperbrowser.ai
HYPERBROWSER_API_KEY=your_hyperbrowser_key_here

# Browserless - Clean headless browser sessions
# Get key at: https://browserless.io
BROWSERLESS_API_KEY=your_browserless_key_here

# HasData - Simpler than running your own Playwright for heavy JS sites
# Get key at: https://hasdata.com
HASDATA_API_KEY=your_hasdata_key_here

# Olostep - AI-powered web scraping and extraction
# Get key at: https://olostep.com
OLOSTEP_API_KEY=your_olostep_key_here

# Apify - Cloud-based Scrapy and actors
# Get key at: https://apify.com
APIFY_API_KEY=your_apify_key_here

# Oxylabs - Google Fast Search API and proxies
# Get credentials at: https://oxylabs.io
OXYLABS_USERNAME=your_oxylabs_username
OXYLABS_PASSWORD=your_oxylabs_password
